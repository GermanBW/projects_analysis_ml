   "source": [
    "def f_hist_box_3(hb1, hb2, hb3, bins, title, xlabel, ylabel):\n",
    "    # Создаем фигуру и оси\n",
    "    f, (ax_box, ax_hist) = plt.subplots(\n",
    "        2, sharex=True, figsize=(12, 6),\n",
    "        gridspec_kw={\"height_ratios\": (0.2, 0.8)}\n",
    "    )\n",
    "\n",
    "    # Визуализация boxplot\n",
    "    sns.boxplot(data=[hb1, hb2, hb3], orient=\"h\", ax=ax_box)\n",
    "    ax_box.set(yticks=[0, 1, 2], yticklabels=['geo_data_0', 'geo_data_1', 'geo_data_2'])\n",
    "    ax_box.set_title('Boxplot')\n",
    "\n",
    "    # Расчет диапазона для гистограммы\n",
    "    min_range = min(hb1.min(), hb2.min(), hb3.min())\n",
    "    max_range = max(hb1.max(), hb2.max(), hb3.max())\n",
    "\n",
    "    # Визуализация гистограммы\n",
    "    ax_hist.hist(\n",
    "        [hb1, hb2, hb3],\n",
    "        bins=bins,\n",
    "        range=(min_range, max_range),\n",
    "        label=['geo_data_0', 'geo_data_1', 'geo_data_2'],\n",
    "        alpha=0.7,\n",
    "        edgecolor='black'\n",
    "    )\n",
    "\n",
    "    # Настройка легенды\n",
    "    ax_hist.legend(loc='upper right')\n",
    "\n",
    "    # Общие подписи и заголовки\n",
    "    f.suptitle(title, fontsize=16)\n",
    "    ax_hist.set_xlabel(xlabel, fontsize=14)\n",
    "    ax_hist.set_ylabel(ylabel, fontsize=14)\n",
    "\n",
    "    plt.tight_layout(rect=[0, 0, 1, 0.95])  # чтобы не перекрывалось с заголовком\n",
    "    plt.show()\n"
   ]
  },
