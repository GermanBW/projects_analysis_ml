   "source": [
    "def f_hist_box_1(hb1, bins, title, xlabel, ylabel):\n",
    "    # Создаем фигуру и оси\n",
    "    f, (ax_box, ax_hist) = plt.subplots(\n",
    "        2, sharex=True, figsize=(10, 5),\n",
    "        gridspec_kw={\"height_ratios\": (0.15, 0.85)}\n",
    "    )\n",
    "\n",
    "    # Визуализация boxplot\n",
    "    sns.boxplot(data=hb1, orient=\"h\", ax=ax_box)\n",
    "    ax_box.set(yticks=[], ylabel='')  # Убираем y-метки для boxplot\n",
    "\n",
    "    # Расчет диапазона для гистограммы\n",
    "    min_range = hb1.min()\n",
    "    max_range = hb1.max()\n",
    "\n",
    "    # Визуализация гистограммы\n",
    "    ax_hist.hist(\n",
    "        hb1,\n",
    "        bins=bins,\n",
    "        range=(min_range, max_range),\n",
    "        label=hb1.name if hasattr(hb1, 'name') else 'Data',\n",
    "        edgecolor='black',\n",
    "        alpha=0.7\n",
    "    )\n",
    "\n",
    "    # Настройка легенды (если есть метка)\n",
    "    if hasattr(hb1, 'name'):\n",
    "        ax_hist.legend(loc='upper right')\n",
    "\n",
    "    # Общие подписи и заголовки\n",
    "    f.suptitle(title, fontsize=16)\n",
    "    ax_hist.set_xlabel(xlabel, fontsize=14)\n",
    "    ax_hist.set_ylabel(ylabel, fontsize=14)\n",
    "\n",
    "    plt.tight_layout(rect=[0, 0, 1, 0.95])  # чтобы не перекрывалось с заголовком\n",
    "    plt.show()\n"
   ]
  },
